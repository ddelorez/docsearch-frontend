# ── Keycloak / OIDC ─────────────────────────────────────────────────────────
# Base URL of your Keycloak instance (no trailing slash)
KEYCLOAK_URL=https://keycloak.example.com
# Keycloak realm name
KEYCLOAK_REALM=internal
# Client ID registered in Keycloak
KEYCLOAK_CLIENT_ID=docsearch-frontend
# Client secret (from Keycloak client credentials)
KEYCLOAK_CLIENT_SECRET=changeme

# ── Backend RAG Service ──────────────────────────────────────────────────────
# URL of the internal RAG/search API
RAG_SERVICE_URL=http://rag-01:8000

# ── Application ──────────────────────────────────────────────────────────────
# Cryptographically random secret key for session signing
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-real-secret-key

# Comma-separated list of AD groups allowed access (leave empty to allow all)
# Example: ALLOWED_AD_GROUPS=docsearch-users,docsearch-admins
ALLOWED_AD_GROUPS=

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
