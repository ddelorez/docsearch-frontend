# ── Authelia / OIDC ─────────────────────────────────────────────────────────
# Domain used for auth cookies (must contain a period or be an IP, e.g. docsearch.example.com or 127.0.0.1)
# For localhost development use: AUTH_COOKIE_DOMAIN=127.0.0.1
AUTH_COOKIE_DOMAIN=sgisearch.sgi01.local
# Base URL of Authelia instance (internal Docker network — used for server-to-server calls)
OIDC_ISSUER_URL=http://authelia:9091
# Public-facing URL for Authelia (browser redirects to OIDC login page)
# Must match the nginx proxy path for Authelia, e.g. "https://sgisearch.sgi01.local/authelia"
AUTHELIA_PUBLIC_URL=https://sgisearch.sgi01.local/authelia
# OIDC client ID
OIDC_CLIENT_ID=docsearch-frontend
# OIDC client secret (plain text, used by frontend)
OIDC_CLIENT_SECRET=changeme-generate-a-strong-secret
# Whether to verify SSL certificates when contacting the OIDC provider.
# Set to false when using self-signed certificates in internal environments.
OIDC_VERIFY_SSL=true
# Session secret (64 hex characters)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=changeme-generate-a-64-char-hex-string
# OIDC HMAC secret (32+ characters)
# Generate with: python -c "import secrets; print(secrets.token_hex(16))"
OIDC_HMAC_SECRET=changeme-generate-a-32-char-hex-string
# Authelia storage encryption key (32+ characters)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AUTHELIA_STORAGE_ENCRYPTION_KEY=changeme-generate-a-32-char-hex-string
# JWT secret for password reset (embedded into authelia.yml by generate-secrets.sh)
# Stored here for persistence across script re-runs — not read by Authelia directly
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
RESET_PASSWORD_JWT_SECRET=changeme-generate-a-32-char-hex-string

# ── Backend RAG Service ──────────────────────────────────────────────────────
# URL of the internal RAG/search API
RAG_SERVICE_URL=http://rag-01:8000

# ── Application ──────────────────────────────────────────────────────────────
# Cryptographically random secret key for session signing
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-real-secret-key

# Comma-separated list of AD groups allowed access (leave empty to allow all)
# Example: ALLOWED_AD_GROUPS=docsearch-users,docsearch-admins
ALLOWED_AD_GROUPS=

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
